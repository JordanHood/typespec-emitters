`;

exports[`example emitter output > emits model without example unchanged 1`] = `
"import { type Static, Type } from "typebox";

export const user = Type.Object({
  name: Type.String(),
  age: Type.Integer({
    minimum: -2147483648,
    maximum: 2147483647
